{
	"name": "svelte-kit-bun",
	"version": "0.5.0",
	"description": "Experimental adapter for SvelteKit apps that compiles to a Bun single-file executable",
	"keywords": [
		"adapter",
		"bun",
		"executable",
		"svelte",
		"sveltekit",
		"single-file-executable"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mastermakrela/svelte-kit-bun.git"
	},
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"import": "./index.js"
		},
		"./package.json": "./package.json"
	},
	"types": "index.d.ts",
	"files": [
		"files",
		"src",
		"index.js",
		"index.d.ts",
		"ambient.d.ts"
	],
	"workspaces": [
		"tests/fixtures/*"
	],
	"scripts": {
		"test": "vitest run",
		"check": "tsc",
		"lint": "prettier --check .",
		"format": "bun run lint --write"
	},
	"devDependencies": {
		"@sveltejs/kit": "^2.57.1",
		"@types/bun": "^1.3.0",
		"@types/node": "^18.19.119",
		"typescript": "^6.0.2",
		"vitest": "^4.0.0"
	},
	"peerDependencies": {
		"@sveltejs/kit": "^2.4.0"
	}
}
