{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"skipLibCheck": true,
		"target": "es2022",
		"module": "node16",
		"moduleResolution": "node16",
		"paths": {
			"@sveltejs/kit": ["../kit/types/index"]
		},
		"types": ["node", "bun"]
	},
	"include": [
		"index.js",
		"src/**/*.js",
		"files/**/*.js",
		"tests/*.js",
		"tests/*.ts",
		"ambient.d.ts",
		"index.d.ts"
	]
}
